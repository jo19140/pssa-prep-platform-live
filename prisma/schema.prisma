generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?
  name            String
  role            String
  emailVerifiedAt DateTime?
  dateOfBirth     DateTime?
  parentalConsentRequired Boolean @default(false)
  parentalConsentAt DateTime?
  accountDeletedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  teacherProfile  TeacherProfile?
  studentProfile  StudentProfile?
  parentProfile   ParentProfile?
  sessions        TestSession[]
  reportSchedules ReportSchedule[]
  lessonProgress  StudentLessonProgress[]
  questAttempts   LearningQuestAttempt[]
  readingCoachAttempts ReadingCoachAttempt[]
  readingCoachAssignments ReadingCoachAssignment[] @relation("ReadingCoachAssignedBy")
  resourceLinks   ResourceLink[]
  resourceSuggestions ResourceSuggestion[] @relation("ResourceSuggester")
  reviewedResourceSuggestions ResourceSuggestion[] @relation("ResourceReviewer")
  tutorMemory     TutorAgentMemory?
  tutorMessages   TutorAgentMessage[]
  passwordResetTokens PasswordResetToken[]
  verificationTokens VerificationToken[]
  lessonReviews   LessonReview[]
  parentalConsent ParentalConsent?
  dataSubjectRequests DataSubjectRequest[] @relation("DSRRequester")
  processedDataSubjectRequests DataSubjectRequest[] @relation("DSRProcessor")
}

model PendingStudentSignup {
  id                String   @id @default(cuid())
  name              String
  email             String
  passwordHash      String
  joinCode          String
  dateOfBirth       DateTime
  parentName        String
  parentEmail       String
  parentPhone       String?
  consentVersion    String
  consentText       String   @db.Text
  verificationToken String   @unique
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([parentEmail])
}

model ParentalConsent {
  id                String   @id @default(cuid())
  studentUserId     String   @unique
  parentName        String
  parentEmail       String
  parentPhone       String?
  consentVersion    String
  consentText       String   @db.Text
  consentedAt       DateTime?
  ipAddress         String?
  verificationToken String?  @unique
  verifiedAt        DateTime?
  revokedAt         DateTime?
  revokedReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           User     @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@index([parentEmail])
}

model DataSubjectRequest {
  id            String   @id @default(cuid())
  userId        String
  requestType   String
  status        String   @default("PENDING")
  reasonNotes   String?
  payloadUrl    String?
  completedAt   DateTime?
  expiresAt     DateTime?
  processedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("DSRRequester", fields: [userId], references: [id], onDelete: Cascade)
  processedBy   User?    @relation("DSRProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([userId, requestType])
  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model School {
  id              String           @id @default(cuid())
  name            String
  districtName    String?
  city            String?
  state           String           @default("PA")
  gradeSpan       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teacherProfiles TeacherProfile[]
  studentProfiles StudentProfile[]
  classes         ClassRoom[]

  @@unique([name, districtName])
  @@index([name])
}

model TeacherProfile {
  id         String      @id @default(cuid())
  userId      String      @unique
  schoolId    String?
  schoolName  String
  gradeBand   String?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  school      School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  classes     ClassRoom[]

  students StudentProfile[] @relation("TeacherStudents")
}

model StudentProfile {
  id          String         @id @default(cuid())
  userId      String         @unique
  schoolId    String?
  grade       Int
  schoolName  String
  teacherId   String?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  school      School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher     TeacherProfile? @relation("TeacherStudents", fields: [teacherId], references: [id])
  enrollments Enrollment[]
  parentLinks ParentStudentLink[]

  @@index([schoolId, grade])
}

model ParentProfile {
  id          String             @id @default(cuid())
  userId      String             @unique
  phoneNumber String?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  children    ParentStudentLink[]
}

model ParentStudentLink {
  id               String         @id @default(cuid())
  parentProfileId  String
  studentProfileId String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
}

model ClassRoom {
  id           String       @id @default(cuid())
  name         String
  schoolId     String?
  teacherId    String
  grade        Int
  joinCode     String?      @unique
  joinEnabled  Boolean      @default(true)
  createdAt    DateTime     @default(now())
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  assignments  Assignment[]
  readingCoachAssignments ReadingCoachAssignment[]
  schedules    ReportSchedule[]

  @@index([schoolId, grade])
}

model Enrollment {
  id               String         @id @default(cuid())
  classRoomId      String
  studentProfileId String
  classRoom        ClassRoom      @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([classRoomId, studentProfileId])
  @@index([studentProfileId])
}

model Assessment {
  id          String        @id @default(cuid())
  title       String
  subject     String
  state       String
  grade       Int
  isAdaptive  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  assignments Assignment[]
  sessions    TestSession[]
  questions   AssessmentQuestion[]
  passages    AssessmentPassage[]
}

model AssessmentPassage {
  id              String     @id @default(cuid())
  assessmentId    String
  passageKey      String
  title           String
  passageType     String
  genre           String
  content         String
  wordCountTarget Int
  actualWordCount Int
  hasTable        Boolean    @default(false)
  hasSections     Boolean    @default(false)
  gradeLevel      Int
  tableData       Json?
  metadata        Json
  createdAt       DateTime   @default(now())
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, passageKey])
}

model AssessmentQuestion {
  id             String     @id @default(cuid())
  assessmentId   String
  questionNo     Int
  standardCode   String
  standardLabel  String
  questionType   String
  skill          String
  difficulty     Int
  questionPayload Json
  createdAt      DateTime   @default(now())
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionNo])
}

model Assignment {
  id             String           @id @default(cuid())
  assessmentId   String
  classRoomId    String
  assignedById   String
  status         String  @default("DRAFT")
  dueDate        DateTime?
  createdAt      DateTime         @default(now())
  standards      String
  assignmentType String
  assessment     Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  classRoom      ClassRoom        @relation(fields: [classRoomId], references: [id], onDelete: Cascade)

  @@index([classRoomId, status])
}

model TestSession {
  id               String          @id @default(cuid())
  userId           String
  assessmentId     String
  startedAt        DateTime        @default(now())
  submittedAt      DateTime?
  currentQuestionNo Int            @default(1)
  scorePercent     Int?
  totalPoints      Int?
  earnedPoints     Int?
  proficiencyBand  String?
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment       Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  responses        ResponseRecord[]
  report           ReportSummary?
  learningPath     LearningPath?
  aiJobs           AiJob[]

  @@index([userId, assessmentId, submittedAt])
}

model AiJob {
  id          String      @id @default(cuid())
  sessionId   String
  jobType     String
  targetId    String?
  status      String      @default("PENDING")
  attempts    Int         @default(0)
  lastError   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  session     TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, jobType, targetId])
  @@index([status, createdAt])
  @@index([sessionId])
}

model ResponseRecord {
  id               String      @id @default(cuid())
  sessionId        String
  questionId       Int
  skill            String
  standardCode     String
  standardLabel    String
  questionType     String
  difficulty       Int
  isCorrect        Boolean
  scorePointsEarned Int
  maxPoints        Int
  errorPattern     String
  timeSpentSec     Int
  answerPayload    Json
  createdAt        DateTime    @default(now())
  session          TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  essayEvaluation  EssayEvaluation?

  @@index([sessionId])
}

model EssayEvaluation {
  id               String         @id @default(cuid())
  responseRecordId String         @unique
  score            Int
  maxScore         Int            @default(4)
  performanceBand  String
  strengths        Json
  areasForGrowth   Json
  feedback         String
  nextSteps        Json
  rubricBreakdown  Json
  gradingProvider  String
  teacherScore     Int?
  teacherFeedback  String?
  teacherRubricBreakdown Json?
  reviewedAt       DateTime?
  reviewedById     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  responseRecord   ResponseRecord @relation(fields: [responseRecordId], references: [id], onDelete: Cascade)
}

model ReportSummary {
  id               String      @id @default(cuid())
  sessionId        String      @unique
  percentScore     Int
  performanceBand  String
  strongestSkill   String?
  weakestSkill     String?
  summaryPayload   Json
  createdAt        DateTime    @default(now())
  growthFromPrevious Int?
  previousReportId String?
  session          TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model LearningPath {
  id              String             @id @default(cuid())
  sessionId       String             @unique
  generatedBy     String             @default("DETERMINISTIC")
  aiStatus        String             @default("NOT_REQUESTED")
  aiSummary       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  session         TestSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items           LearningPathItem[]
  lessons         LearningLesson[]
}

model LearningPathItem {
  id               String       @id @default(cuid())
  learningPathId   String
  order            Int
  standardCode     String
  standardLabel    String
  skill            String
  priority         Int
  title            String
  recommendation   String
  activityType     String
  difficulty       String
  estimatedMinutes Int
  rationale        String
  practicePrompt   String
  aiExplanation    String?
  sourcePayload    Json
  status           String       @default("TODO")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  learningPath     LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  lesson           LearningLesson?

  @@unique([learningPathId, order])
}

model LearningLesson {
  id                   String                  @id @default(cuid())
  learningPathId       String
  learningPathItemId   String?                 @unique
  gradeLevel           Int
  standardCode         String
  standardLabel        String
  skill                String
  priority             Int
  title                String
  whyAssigned          String
  lessonExplanation    String
  workedExample        String
  resourceTitle        String?
  resourceUrl          String?
  resourceProvider     String?
  resourceDescription  String?
  heroResourceLinkId   String?
  guidedPractice       Json
  independentPractice  Json
  exitTicket           Json
  masteryCheck         Json
  retestRecommendation String
  generatedBy          String                  @default("DETERMINISTIC")
  aiStatus             String                  @default("NOT_REQUESTED")
  reviewStatus         String                  @default("PENDING_REVIEW")
  approvedAt           DateTime?
  approvedById         String?
  rejectedAt           DateTime?
  rejectedById         String?
  reviews              LessonReview[]
  sourcePayload        Json
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  learningPath         LearningPath            @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  learningPathItem     LearningPathItem?       @relation(fields: [learningPathItemId], references: [id], onDelete: SetNull)
  heroResourceLink     ResourceLink?           @relation(fields: [heroResourceLinkId], references: [id], onDelete: SetNull)
  items                LearningLessonItem[]
  steps                LessonStep[]
  progress             StudentLessonProgress[]
  questAttempts        LearningQuestAttempt[]
}

model LessonStep {
  id              String         @id @default(cuid())
  lessonId        String
  order           Int
  stepType        String
  title           String
  bodyText        String
  narrationScript String
  audioUrl        String?
  imageUrl        String?
  imagePrompt     String?
  checkQuestion   Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  lesson          LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
  @@index([lessonId])
}

model LessonCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  gradeLevel   Int
  standardCode String
  skill        String
  commonError  String
  payload      Json
  generatedBy  String
  modelHint    String?
  reviewStatus String   @default("PENDING_REVIEW")
  approvedAt   DateTime?
  approvedById String?
  rejectedAt   DateTime?
  rejectedById String?
  doNotRetryUntil DateTime?
  createdAt    DateTime @default(now())
  hitCount     Int      @default(0)
  lastUsedAt   DateTime @default(now())
  reviews      LessonReview[]

  @@index([gradeLevel, standardCode, skill])
}

model LessonReview {
  id                String              @id @default(cuid())
  lessonCacheId     String?
  lessonId          String?
  status            String              @default("PENDING")
  reviewedById      String?
  reviewedAt        DateTime?
  reviewerNotes     String?
  aiOriginalContent Json?
  currentContent    Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  lessonCache       LessonCache?        @relation(fields: [lessonCacheId], references: [id], onDelete: Cascade)
  lesson            LearningLesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  reviewedBy        User?               @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
  editInstructions  AiEditInstruction[]

  @@index([status, createdAt])
  @@index([lessonCacheId])
  @@index([reviewedById])
}

model AiEditInstruction {
  id              String       @id @default(cuid())
  lessonReviewId  String
  sectionType     String
  sectionIndex    Int?
  instructionText String
  originalContent Json
  revisedContent  Json
  accepted        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  lessonReview    LessonReview @relation(fields: [lessonReviewId], references: [id], onDelete: Cascade)

  @@index([sectionType])
}

model LearningLessonItem {
  id        String         @id @default(cuid())
  lessonId  String
  itemType  String
  title     String
  content   Json
  order     Int
  createdAt DateTime       @default(now())
  lesson    LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
}

model StudentLessonProgress {
  id                    String         @id @default(cuid())
  lessonId              String
  userId                String
  status                String         @default("NOT_STARTED")
  guidedResponses       Json?
  independentResponses  Json?
  exitTicketResponses   Json?
  masteryScore          Int?
  masteryStatus         String         @default("NOT_STARTED")
  startedAt             DateTime?
  completedAt           DateTime?
  masteredAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  lesson                LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([userId])
}

model LearningQuestAttempt {
  id              String         @id @default(cuid())
  lessonId        String
  userId          String
  worldKey        String
  questKey        String
  skill           String
  standardCode    String
  score           Int
  maxScore        Int
  xpEarned        Int
  status          String         @default("COMPLETED")
  responses       Json
  feedback        Json
  createdAt       DateTime       @default(now())
  lesson          LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([lessonId, userId])
  @@index([standardCode, skill])
}

model ReadingCoachAssignment {
  id            String                @id @default(cuid())
  classRoomId   String
  assignedById  String
  title         String
  gradeLevel    Int
  activityType  String                @default("READ_ALOUD")
  expectedText  String
  status        String                @default("ASSIGNED")
  dueDate       DateTime?
  createdAt     DateTime              @default(now())
  classRoom     ClassRoom             @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  assignedBy    User                  @relation("ReadingCoachAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  attempts      ReadingCoachAttempt[]

  @@index([classRoomId, status])
  @@index([assignedById, createdAt])
}

model ReadingCoachAttempt {
  id             String   @id @default(cuid())
  assignmentId   String?
  userId         String
  gradeLevel     Int
  activityType   String
  expectedText   String
  transcript     String
  wordCount      Int
  correctWords   Int
  accuracy       Int
  wordsPerMinute Int?
  focusAreas     Json
  miscues         Json
  feedback        Json
  provider        String
  audioSeconds    Int?
  createdAt       DateTime @default(now())
  assignment      ReadingCoachAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([userId, createdAt])
  @@index([gradeLevel, activityType])
}

model ResourceLink {
  id           String   @id @default(cuid())
  gradeLevel   Int?
  standardCode String
  skill        String
  title        String
  url          String
  provider     String
  description  String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  heroLessons  LearningLesson[]
  suggestions  ResourceSuggestion[]

  @@index([gradeLevel, standardCode])
  @@index([skill])
}

model ResourceSuggestion {
  id             String   @id @default(cuid())
  teacherUserId  String
  url            String
  title          String
  provider       String
  gradeLevel     Int?
  standardCode   String?
  skill          String?
  description    String?
  rationale      String?
  status         String   @default("PENDING")
  reviewedById   String?
  reviewedAt     DateTime?
  reviewerNotes  String?
  resourceLinkId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        User     @relation("ResourceSuggester", fields: [teacherUserId], references: [id], onDelete: Cascade)
  reviewedBy     User?    @relation("ResourceReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  resourceLink   ResourceLink? @relation(fields: [resourceLinkId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([teacherUserId])
}

model TutorAgentMemory {
  id              String   @id @default(cuid())
  userId          String   @unique
  gradeLevel      Int?
  learnerSummary  String
  weakStandards   Json
  masteredSkills  Json
  preferredSupports Json
  lastInteractionAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorAgentMessage {
  id          String   @id @default(cuid())
  userId      String
  role        String
  intent      String
  message     String
  response    String
  artifacts   Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReportSchedule {
  id            String                  @id @default(cuid())
  teacherUserId String
  classRoomId   String?
  frequency     String
  sendDay       Int?
  sendHour      Int                     @default(7)
  isEnabled     Boolean                 @default(true)
  reportType    String                  @default("GROWTH")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  teacher       User                    @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  classRoom     ClassRoom?              @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
}
