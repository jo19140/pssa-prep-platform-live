  costUsd                        Float?
  studentEventId                 String?
  parentDecisionId               String?
  retentionTier                  String                 @default("SERVICE")
  deleteAfterDate                DateTime?
  occurredAt                     DateTime               @default(now())
  studentEvent                   StudentEvent?          @relation(fields: [studentEventId], references: [id], onDelete: SetNull)
  parentDecision                 ModelDecision?         @relation("DecisionChain", fields: [parentDecisionId], references: [id], onDelete: SetNull)
  childDecisions                 ModelDecision[]        @relation("DecisionChain")
  outcomes                       ModelDecisionOutcome[]
  diagnosticItemFirstLookReviews DiagnosticItem[]       @relation("DiagnosticItemFirstLookReview")
  lessonPartFirstLookReviews     LessonPart[]           @relation("LessonPartFirstLookReview")
  passageFirstLookReviews        Passage[]              @relation("PassageFirstLookReview")

  @@index([decisionType, occurredAt])
  @@index([modelProvider, modelName, occurredAt])
  @@index([inputHash])
  @@index([studentEventId])
  @@index([deleteAfterDate])
}

model ModelDecisionOutcome {
  id              String        @id @default(cuid())
  modelDecisionId String
  outcomeType     String
  outcomeScore    Float?
  outcomeLabel    String?
  metricJson      Json?
  measuredAt      DateTime      @default(now())
  modelDecision   ModelDecision @relation(fields: [modelDecisionId], references: [id], onDelete: Cascade)

  @@unique([modelDecisionId, outcomeType])
  @@index([outcomeType, measuredAt])
}

model EventExportBatch {
  id                  String    @id @default(cuid())
  batchName           String    @unique
  exportPurpose       String
  eventCount          Int
  decisionCount       Int
  eventTypeFilter     String[]
  decisionTypeFilter  String[]
  dateRangeStart      DateTime?
  dateRangeEnd        DateTime?
  consentTierMinimum  String
  excludedRecordCount Int       @default(0)
  manifestStorageKey  String
  manifestJsonl       String    @db.Text
  exportedByUserId    String
  exportedAt          DateTime  @default(now())
  notes               String?   @db.Text

  @@index([exportPurpose, exportedAt])
}

model DataDeletionLog {
  id              String   @id @default(cuid())
  studentUserId   String?
  recordType      String
  recordId        String?
  deletionReason  String
  deletedByUserId String?
  deletedAt       DateTime @default(now())
  metadataJson    Json?

  @@index([studentUserId, deletedAt])
  @@index([recordType, deletedAt])
}

model VoiceConsentDecision {
  id                 String       @id @default(cuid())
  voiceConsentId     String
  changeType         String
  previousValue      Json?
  newValue           Json
  consentTextVersion String
  ipAddress          String?
  userAgent          String?
  changedByUserId    String?
  createdAt          DateTime     @default(now())
  voiceConsent       VoiceConsent @relation(fields: [voiceConsentId], references: [id], onDelete: Cascade)

  @@index([voiceConsentId, createdAt])
}

model LabeledVoiceSegment {
  id                 String        @id @default(cuid())
  voiceSessionId     String
  segmentStartMs     Int
  segmentEndMs       Int
  segmentAudioKey    String?
  expectedText       String        @db.Text
  asrTranscript      String        @db.Text
  humanTranscript    String?       @db.Text
  miscueType         String?
  phonogramCode      String?
  syllableType       SyllableType?
  dialectTransferTag String?
  uncertaintyScore   Float?
  routedFromQueue    Boolean       @default(false)
  skippedAt          DateTime?
  skippedByUserId    String?
  skipReason         String?       @db.Text
  labeledByUserId    String?
  labeledAt          DateTime?
  labelerNotes       String?       @db.Text
  isEvalSet          Boolean       @default(false)
  qaParentSegmentId  String?
  createdAt          DateTime      @default(now())
  voiceSession       VoiceSession  @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)

  @@index([voiceSessionId, segmentStartMs])
  @@index([labeledAt])
  @@index([miscueType])
  @@index([isEvalSet])
  @@index([uncertaintyScore])
}

model TrainingCorpusBatch {
  id                    String   @id @default(cuid())
  batchName             String   @unique
  exportPurpose         String
  segmentCount          Int
  totalDurationMs       Int
  manifestStorageKey    String
  exportedAt            DateTime @default(now())
  exportedByUserId      String
  minimumConsentVersion String
  excludedSegmentCount  Int      @default(0)
  manifestJsonl         String   @db.Text
  notes                 String?  @db.Text

  @@index([exportPurpose, exportedAt])
}

model VoiceAudioDeletionLog {
  id                String   @id @default(cuid())
  voiceSessionId    String?
  studentUserId     String?
  audioStorageKey   String
  deletionReason    String
  triggeredByUserId String?
  deletedAt         DateTime @default(now())

  @@index([studentUserId, deletedAt])
  @@index([deletedAt])
}

model VoiceAudioAccessLog {
  id             String   @id @default(cuid())
  voiceSessionId String?
  segmentId      String?
  accessedById   String
  accessPurpose  String
  createdAt      DateTime @default(now())

  @@index([voiceSessionId, createdAt])
  @@index([segmentId, createdAt])
  @@index([accessedById, createdAt])
}

model ResourceLink {
  id              String               @id @default(cuid())
  gradeLevel      Int?
  standardCode    String
  skill           String
  title           String
  url             String
  provider        String
  description     String?
  tier            String?
  belowGradeLevel Boolean              @default(false)
  aboveGradeLevel Boolean              @default(false)
  createdById     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  createdBy       User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  heroLessons     LearningLesson[]
  suggestions     ResourceSuggestion[]

  @@index([gradeLevel, standardCode])
  @@index([belowGradeLevel, standardCode])
  @@index([aboveGradeLevel, standardCode])
  @@index([skill])
}

model StateRequests {
  id           String   @id @default(cuid())
  userId       String?
  email        String?
  stateCode    String
  requestNotes String?  @db.Text
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([stateCode, createdAt])
}

model ResourceSuggestion {
  id             String        @id @default(cuid())
  teacherUserId  String
  url            String
  title          String
  provider       String
  gradeLevel     Int?
  standardCode   String?
  skill          String?
  description    String?
  rationale      String?
  status         String        @default("PENDING")
  reviewedById   String?
  reviewedAt     DateTime?
  reviewerNotes  String?
  resourceLinkId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  teacher        User          @relation("ResourceSuggester", fields: [teacherUserId], references: [id], onDelete: Cascade)
  reviewedBy     User?         @relation("ResourceReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  resourceLink   ResourceLink? @relation(fields: [resourceLinkId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([teacherUserId])
}

model TutorAgentMemory {
  id                String    @id @default(cuid())
  userId            String    @unique
  gradeLevel        Int?
  learnerSummary    String
  weakStandards     Json
  masteredSkills    Json
  preferredSupports Json
  lastInteractionAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorAgentMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  intent    String
  message   String
  response  String
  artifacts Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReportSchedule {
  id            String     @id @default(cuid())
  teacherUserId String
  classRoomId   String?
  frequency     String
  sendDay       Int?
  sendHour      Int        @default(7)
  isEnabled     Boolean    @default(true)
  reportType    String     @default("GROWTH")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  teacher       User       @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  classRoom     ClassRoom? @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
}

model PhonogramFamily {
  id                String             @id @default(cuid())
  code              String             @unique
  category          String
  syllableType      String
  exampleWords      Json
  introductionOrder Int
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  masteryRecords    PhonogramMastery[]

  @@index([category, introductionOrder])
}
