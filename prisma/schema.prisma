generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EhriPhase {
  PRE_ALPHABETIC
  PARTIAL_ALPHABETIC
  FULL_ALPHABETIC
  CONSOLIDATED_ALPHABETIC
}

enum SynesisProgram {
  VENUS
  MERCURY
  MARS
  EARTH
}

enum TestPrepModule {
  PSSA
  STAAR
  FSA
  MCAS
}

enum LiteracyStrand {
  PHONEMIC_AWARENESS
  DECODING
  MORPHOLOGY
  FLUENCY
  VOCABULARY
  COMPREHENSION
}

enum SyllableType {
  CLOSED
  OPEN
  VCE
  VOWEL_TEAM
  R_CONTROLLED
  CONSONANT_LE
}

enum MasteryLevel {
  UNTESTED
  NOT_YET
  DEVELOPING
  SOLID
  MASTERED
}

enum PssaSourceType {
  internal_original
  released_sampler
  unknown
}

enum PssaLicenseStatus {
  cleared
  unresolved
  restricted
}

enum PssaReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PssaItemStatus {
  candidate
  pilot_ready
  deprecated_superseded
  retired
}

enum PssaAlignmentStatus {
  ALIGNED
  NEEDS_CROSSWALK
  ANOMALY
}

enum PssaInteractionType {
  MCQ
  EBSR
  MULTI_SELECT
  INLINE_DROPDOWN
  MATCHING_GRID
  HOT_TEXT
  DRAG_DROP
  SHORT_ANSWER
  TDA
}

enum PssaStreamType {
  MCQ
  EBSR
  MULTI_SELECT
  HOT_TEXT
  INLINE_DROPDOWN
  MATCHING_GRID
  DRAG_DROP
  CONVENTIONS
  SHORT_ANSWER
  TDA
}

enum PssaAuditSeverity {
  BLOCKER
  WARN
  INFO
}

enum PssaAuditResultStatus {
  PASS
  WARN
  FAIL
}

enum PssaStudentReadyBlockedReason {
  NONE
  PENDING_REVIEW
  STALE_AUDIT_CONTRACT
  STALE_SOURCE_SCAN
  CONTENT_HASH_DRIFT
  FAILED_LATEST_AUDIT
  DEPRECATED_SUPERSEDED
}

enum PssaPassageRole {
  primary
  secondary
  evidence_source
}

enum PssaImportMode {
  dry_run
  write
}

enum PssaAuditTargetType {
  item
  passage
  batch
}

model User {
  id                                String           @id @default(cuid())
  email                             String           @unique
  passwordHash                      String?
  name                              String
  role                              String
  emailVerifiedAt                   DateTime?
  dateOfBirth                       DateTime?
  parentalConsentRequired           Boolean          @default(false)
  parentalConsentAt                 DateTime?
  accountDeletedAt                  DateTime?
  enrolledPrograms                  SynesisProgram[] @default([VENUS])
  enrolledTestPrep                  TestPrepModule[] @default([PSSA])
  synesisMigrationBannerDismissedAt DateTime?
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime         @updatedAt

  teacherProfile               TeacherProfile?
  studentProfile               StudentProfile?
  parentProfile                ParentProfile?
  sessions                     TestSession[]
  reportSchedules              ReportSchedule[]
  lessonProgress               StudentLessonProgress[]
  questAttempts                LearningQuestAttempt[]
  readingCoachAttempts         ReadingCoachAttempt[]
  readingCoachAssignments      ReadingCoachAssignment[] @relation("ReadingCoachAssignedBy")
  resourceLinks                ResourceLink[]
  resourceSuggestions          ResourceSuggestion[]     @relation("ResourceSuggester")
  reviewedResourceSuggestions  ResourceSuggestion[]     @relation("ResourceReviewer")
  tutorMemory                  TutorAgentMemory?
  tutorMessages                TutorAgentMessage[]
  passwordResetTokens          PasswordResetToken[]
  verificationTokens           VerificationToken[]
  lessonReviews                LessonReview[]
  parentalConsent              ParentalConsent?
  dataSubjectRequests          DataSubjectRequest[]     @relation("DSRRequester")
  processedDataSubjectRequests DataSubjectRequest[]     @relation("DSRProcessor")
  literacyProfile              LiteracyProfile?
  stateRequests                StateRequests[]
  voiceConsent                 VoiceConsent?            @relation("StudentConsent")
  studentEvents                StudentEvent[]           @relation("StudentEvents")
}

model PendingStudentSignup {
  id                String   @id @default(cuid())
  name              String
  email             String
  passwordHash      String
  joinCode          String
  dateOfBirth       DateTime
  parentName        String
  parentEmail       String
  parentPhone       String?
  consentVersion    String
  consentText       String   @db.Text
  verificationToken String   @unique
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([parentEmail])
}

model ParentalConsent {
  id                String    @id @default(cuid())
  studentUserId     String    @unique
  parentName        String
  parentEmail       String
  parentPhone       String?
  consentVersion    String
  consentText       String    @db.Text
  consentedAt       DateTime?
  ipAddress         String?
  verificationToken String?   @unique
  verifiedAt        DateTime?
  revokedAt         DateTime?
  revokedReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  student           User      @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@index([parentEmail])
}

model DataSubjectRequest {
  id            String    @id @default(cuid())
  userId        String
  requestType   String
  status        String    @default("PENDING")
  reasonNotes   String?
  payloadUrl    String?
  completedAt   DateTime?
  expiresAt     DateTime?
  processedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation("DSRRequester", fields: [userId], references: [id], onDelete: Cascade)
  processedBy   User?     @relation("DSRProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([userId, requestType])
  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model School {
  id              String           @id @default(cuid())
  name            String
  districtName    String?
  city            String?
  state           String           @default("PA")
  gradeSpan       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teacherProfiles TeacherProfile[]
  studentProfiles StudentProfile[]
  classes         ClassRoom[]

  @@unique([name, districtName])
  @@index([name])
}

model TeacherProfile {
  id         String      @id @default(cuid())
  userId     String      @unique
  schoolId   String?
  schoolName String
  gradeBand  String?
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  school     School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  classes    ClassRoom[]

  students StudentProfile[] @relation("TeacherStudents")
}

model StudentProfile {
  id          String              @id @default(cuid())
  userId      String              @unique
  schoolId    String?
  grade       Int
  schoolName  String
  teacherId   String?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  school      School?             @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher     TeacherProfile?     @relation("TeacherStudents", fields: [teacherId], references: [id])
  enrollments Enrollment[]
  parentLinks ParentStudentLink[]

  @@index([schoolId, grade])
}

model ParentProfile {
  id          String              @id @default(cuid())
  userId      String              @unique
  phoneNumber String?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  children    ParentStudentLink[]
}

model ParentStudentLink {
  id               String         @id @default(cuid())
  parentProfileId  String
  studentProfileId String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
}

model ClassRoom {
  id                      String                   @id @default(cuid())
  name                    String
  schoolId                String?
  teacherId               String
  grade                   Int
  joinCode                String?                  @unique
  joinEnabled             Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  school                  School?                  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher                 TeacherProfile           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments             Enrollment[]
  assignments             Assignment[]
  readingCoachAssignments ReadingCoachAssignment[]
  schedules               ReportSchedule[]

  @@index([schoolId, grade])
}

model Enrollment {
  id               String         @id @default(cuid())
  classRoomId      String
  studentProfileId String
  classRoom        ClassRoom      @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([classRoomId, studentProfileId])
  @@index([studentProfileId])
}

model Assessment {
  id              String               @id @default(cuid())
  title           String
  subject         String
  state           String
  grade           Int
  isAdaptive      Boolean              @default(true)
  ehriPhaseAtTime EhriPhase?
  lexileBand      Int?
  createdAt       DateTime             @default(now())
  assignments     Assignment[]
  sessions        TestSession[]
  questions       AssessmentQuestion[]
  passages        AssessmentPassage[]
}

model AssessmentPassage {
  id              String     @id @default(cuid())
  assessmentId    String
  passageKey      String
  title           String
  passageType     String
  genre           String
  content         String
  wordCountTarget Int
  actualWordCount Int
  hasTable        Boolean    @default(false)
  hasSections     Boolean    @default(false)
  gradeLevel      Int
  tableData       Json?
  metadata        Json
  createdAt       DateTime   @default(now())
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, passageKey])
}

model AssessmentQuestion {
  id              String     @id @default(cuid())
  assessmentId    String
  questionNo      Int
  standardCode    String
  standardLabel   String
  questionType    String
  skill           String
  difficulty      Int
  questionPayload Json
  createdAt       DateTime   @default(now())
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionNo])
}

model PssaStandardsCrosswalk {
  id                        String   @id @default(cuid())
  subject                   String
  gradeLevel                Int
  reportingCategory         String
  reportingCategoryTitle    String
  assessmentAnchor          String
  assessmentAnchorTitle     String
  anchorDescriptor          String
  anchorDescriptorText      String   @db.Text
  eligibleContent           String
  eligibleContentText       String   @db.Text
  dokCeiling                String?
  primaryPaCoreStandardCode String?
  mappingGranularity        String
  mappingConfidence         String
  sourceDocument            String
  sourceVersionYear         Int
  sourceUpdatedYear         Int
  sourceAnomalyJson         Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  paCoreStandards PssaCrosswalkPaCoreStandard[]
  pssaItems       PssaItem[]

  @@unique([subject, gradeLevel, eligibleContent, sourceVersionYear])
  @@index([subject, gradeLevel, assessmentAnchor])
  @@index([subject, gradeLevel, reportingCategory])
  @@index([eligibleContent])
}

model PssaCrosswalkPaCoreStandard {
  id           String   @id @default(cuid())
  crosswalkId  String
  standardCode String
  createdAt    DateTime @default(now())

  crosswalk PssaStandardsCrosswalk @relation(fields: [crosswalkId], references: [id], onDelete: Cascade)

  @@unique([crosswalkId, standardCode])
  @@index([standardCode])
}

model PssaPassage {
  id                        String                        @id @default(cuid())
  title                     String
  gradeLevel                Int
  subject                   String                        @default("ELA")
  passageType               String
  text                      String                        @db.Text
  wordCount                 Int
  sourceType                PssaSourceType                @default(unknown)
  sourceName                String?
  sourceCitation            String?                       @db.Text
  licenseStatus             PssaLicenseStatus             @default(unresolved)
  commercialUseAllowed      Boolean                       @default(false)
  needsLegalReview          Boolean                       @default(true)
  reviewStatus              PssaReviewStatus              @default(PENDING)
  itemStatus                PssaItemStatus                @default(candidate)
  approvedAt                DateTime?
  reviewedBy                String?
  provenanceJson            Json
  contentHash               String
  latestAuditContentHash    String?
  approvedContentHash       String?
  auditContractVersion      String?
  sourceScanVersion         String?
  latestSourceCorpusHash    String?
  latestAuditResult         PssaAuditResultStatus?
  latestAuditAt             DateTime?
  studentReadyBlockedReason PssaStudentReadyBlockedReason @default(PENDING_REVIEW)
  retiredAt                 DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  items        PssaItemPassageLink[]
  auditResults PssaAuditResult[]
  reviewLogs   PssaReviewLog[]

  @@index([gradeLevel, subject, reviewStatus, itemStatus])
  @@index([sourceType, licenseStatus])
  @@index([retiredAt])
  @@index([contentHash])
}

model PssaItem {
  id                        String                        @id @default(cuid())
  module                    TestPrepModule                @default(PSSA)
  subject                   String                        @default("ELA")
  gradeLevel                Int
  standardCode              String
  assessmentAnchor          String?
  eligibleContent           String?
  eligibleContentRefId      String?
  reportingCategory         String?
  dokLevel                  Int?
  itemType                  String
  skill                     String
  difficultyBand            String?
  interactionType           PssaInteractionType
  interactionSubtype        String?
  responseSpecJson          Json
  correctResponseJson       Json
  scoringJson               Json
  pointValue                Int
  sourceType                PssaSourceType                @default(unknown)
  sourceName                String?
  sourceCitation            String?                       @db.Text
  licenseStatus             PssaLicenseStatus             @default(unresolved)
  commercialUseAllowed      Boolean                       @default(false)
  needsLegalReview          Boolean                       @default(true)
  reviewStatus              PssaReviewStatus              @default(PENDING)
  itemStatus                PssaItemStatus                @default(candidate)
  alignmentStatus           PssaAlignmentStatus           @default(NEEDS_CROSSWALK)
  approvalEligible          Boolean                       @default(false)
  approvedAt                DateTime?
  reviewedBy                String?
  studentPreviewJson        Json?
  responseSpecVersion       String
  auditContractVersion      String
  sourceScanVersion         String
  contentHash               String
  latestAuditContentHash    String?
  approvedContentHash       String?
  latestSourceCorpusHash    String?
  latestAuditResult         PssaAuditResultStatus?
  latestAuditAt             DateTime?
  importedFromFile          String?
  importRunId               String?
  studentReadyBlockedReason PssaStudentReadyBlockedReason @default(PENDING_REVIEW)
  deprecatedReason          String?                       @db.Text
  batchId                   String?
  provenanceJson            Json
  retiredAt                 DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  eligibleContentRef PssaStandardsCrosswalk? @relation(fields: [eligibleContentRefId], references: [id], onDelete: SetNull)
  importRun          PssaImportRun?          @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  batch              PssaItemBatch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  passages           PssaItemPassageLink[]
  auditResults       PssaAuditResult[]
  reviewLogs         PssaReviewLog[]
  supersededBy       PssaItemSupersession[]  @relation("PssaItemSupersededOld")
  supersedes         PssaItemSupersession[]  @relation("PssaItemSupersededNew")

  @@index([gradeLevel, subject, reviewStatus, itemStatus, studentReadyBlockedReason])
  @@index([auditContractVersion, sourceScanVersion])
  @@index([interactionType, interactionSubtype])
  @@index([standardCode, assessmentAnchor, eligibleContent])
  @@index([eligibleContentRefId])
  @@index([alignmentStatus, approvalEligible])
  @@index([batchId])
  @@index([importRunId])
  @@index([contentHash])
  @@index([retiredAt])
}

model PssaItemPassageLink {
  id        String          @id @default(cuid())
  itemId    String
  passageId String
  role      PssaPassageRole
  sortOrder Int
  createdAt DateTime        @default(now())

  item    PssaItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  passage PssaPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@unique([itemId, passageId, role])
  @@index([itemId])
  @@index([passageId, role])
}

model PssaItemBatch {
  id                   String                 @id @default(cuid())
  gradeLevel           Int
  subject              String                 @default("ELA")
  streamType           PssaStreamType
  auditContractVersion String
  sourceScanVersion    String
  sourceCorpusHash     String
  importRunId          String?
  batchAuditResult     PssaAuditResultStatus?
  batchAuditNotes      String?                @db.Text
  createdAt            DateTime               @default(now())

  importRun    PssaImportRun?    @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  items        PssaItem[]
  linterRuns   PssaLinterRun[]
  auditResults PssaAuditResult[]
  reviewLogs   PssaReviewLog[]

  @@index([gradeLevel, subject, streamType, auditContractVersion])
  @@index([importRunId])
}

model PssaItemSupersession {
  id        String   @id @default(cuid())
  oldItemId String
  newItemId String
  reason    String   @db.Text
  createdAt DateTime @default(now())

  oldItem PssaItem @relation("PssaItemSupersededOld", fields: [oldItemId], references: [id], onDelete: Cascade)
  newItem PssaItem @relation("PssaItemSupersededNew", fields: [newItemId], references: [id], onDelete: Restrict)

  @@unique([oldItemId, newItemId])
  @@index([oldItemId])
  @@index([newItemId])
}

model PssaImportRun {
  id                       String         @id @default(cuid())
  runKey                   String         @unique
  mode                     PssaImportMode
  env                      String
  auditContractVersion     String
  sourceScanVersion        String
  sourceCorpusHash         String
  sourceCorpusManifestJson Json
  addedCount               Int            @default(0)
  updatedCount             Int            @default(0)
  skippedCount             Int            @default(0)
  failedCount              Int            @default(0)
  reportPath               String?
  createdAt                DateTime       @default(now())

  items   PssaItem[]
  batches PssaItemBatch[]
}

model PssaLinterRun {
  id                   String   @id @default(cuid())
  runKey               String   @unique
  batchId              String?
  sourceBundlePath     String?
  auditContractVersion String
  sourceScanVersion    String
  sourceCorpusHash     String
  totalResults         Int      @default(0)
  blockerCount         Int      @default(0)
  createdAt            DateTime @default(now())

  batch   PssaItemBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  results PssaAuditResult[]
}

model PssaAuditResult {
  id           String                @id @default(cuid())
  targetType   PssaAuditTargetType
  targetId     String
  itemId       String?
  passageId    String?
  batchId      String?
  linterRunId  String
  ruleId       String
  severity     PssaAuditSeverity
  result       PssaAuditResultStatus
  message      String                @db.Text
  evidenceJson Json?
  createdAt    DateTime              @default(now())

  item      PssaItem?      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  passage   PssaPassage?   @relation(fields: [passageId], references: [id], onDelete: Cascade)
  batch     PssaItemBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  linterRun PssaLinterRun  @relation(fields: [linterRunId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, linterRunId, ruleId])
  @@index([targetType, targetId, result, severity])
  @@index([itemId, result, severity])
  @@index([passageId, result, severity])
  @@index([batchId, ruleId])
  @@index([linterRunId])
}

model PssaReviewLog {
  id             String   @id @default(cuid())
  itemId         String?
  passageId      String?
  batchId        String?
  action         String
  reviewerUserId String?
  notes          String?  @db.Text
  editDiffJson   Json?
  createdAt      DateTime @default(now())

  item    PssaItem?      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  passage PssaPassage?   @relation(fields: [passageId], references: [id], onDelete: Cascade)
  batch   PssaItemBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@index([passageId, createdAt])
  @@index([batchId, createdAt])
}

model Assignment {
  id             String     @id @default(cuid())
  assessmentId   String
  classRoomId    String
  assignedById   String
  status         String     @default("DRAFT")
  dueDate        DateTime?
  createdAt      DateTime   @default(now())
  standards      String
  assignmentType String
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  classRoom      ClassRoom  @relation(fields: [classRoomId], references: [id], onDelete: Cascade)

  @@index([classRoomId, status])
}

model TestSession {
  id                String           @id @default(cuid())
  userId            String
  assessmentId      String
  startedAt         DateTime         @default(now())
  submittedAt       DateTime?
  currentQuestionNo Int              @default(1)
  scorePercent      Int?
  totalPoints       Int?
  earnedPoints      Int?
  proficiencyBand   String?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment        Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  responses         ResponseRecord[]
  report            ReportSummary?
  learningPath      LearningPath?
  aiJobs            AiJob[]

  @@index([userId, assessmentId, submittedAt])
}

model AiJob {
  id          String      @id @default(cuid())
  sessionId   String
  jobType     String
  targetId    String?
  status      String      @default("PENDING")
  attempts    Int         @default(0)
  lastError   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  session     TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, jobType, targetId])
  @@index([status, createdAt])
  @@index([sessionId])
}

model ResponseRecord {
  id                String           @id @default(cuid())
  sessionId         String
  questionId        Int
  skill             String
  standardCode      String
  standardLabel     String
  questionType      String
  difficulty        Int
  isCorrect         Boolean
  scorePointsEarned Int
  maxPoints         Int
  errorPattern      String
  timeSpentSec      Int
  answerPayload     Json
  createdAt         DateTime         @default(now())
  session           TestSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  essayEvaluation   EssayEvaluation?

  @@index([sessionId])
}

model EssayEvaluation {
  id                     String         @id @default(cuid())
  responseRecordId       String         @unique
  score                  Int
  maxScore               Int            @default(4)
  performanceBand        String
  strengths              Json
  areasForGrowth         Json
  feedback               String
  nextSteps              Json
  rubricBreakdown        Json
  gradingProvider        String
  teacherScore           Int?
  teacherFeedback        String?
  teacherRubricBreakdown Json?
  reviewedAt             DateTime?
  reviewedById           String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  responseRecord         ResponseRecord @relation(fields: [responseRecordId], references: [id], onDelete: Cascade)
}

model ReportSummary {
  id                 String      @id @default(cuid())
  sessionId          String      @unique
  percentScore       Int
  performanceBand    String
  strongestSkill     String?
  weakestSkill       String?
  summaryPayload     Json
  createdAt          DateTime    @default(now())
  growthFromPrevious Int?
  previousReportId   String?
  session            TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model LearningPath {
  id          String             @id @default(cuid())
  sessionId   String             @unique
  generatedBy String             @default("DETERMINISTIC")
  aiStatus    String             @default("NOT_REQUESTED")
  aiSummary   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  session     TestSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items       LearningPathItem[]
  lessons     LearningLesson[]
}

model LearningPathItem {
  id               String          @id @default(cuid())
  learningPathId   String
  order            Int
  standardCode     String
  standardLabel    String
  skill            String
  priority         Int
  title            String
  recommendation   String
  activityType     String
  difficulty       String
  estimatedMinutes Int
  rationale        String
